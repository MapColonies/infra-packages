{
  "name": "@map-colonies/openapi-supertest",
  "version": "0.2.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prebuild": "pnpm run clean",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rimraf dist",
    "prepack": "turbo run build",
    "check-dist": "publint && attw --profile node16 --pack .",
    "knip": "knip --directory ../.. --workspace packages/openapi-supertest",
    "api": "api-extractor run --local --verbose",
    "api:check": "api-extractor run --verbose"
  },
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": "github:MapColonies/infra-packages",
  "dependencies": {
    "oas-normalize": "^15.7.0",
    "ts-essentials": "^10.1.1"
  },
  "peerDependencies": {
    "@types/express": "^4.17.21",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@map-colonies/eslint-config": "workspace:^",
    "@map-colonies/tsconfig": "workspace:^",
    "@microsoft/api-extractor": "catalog:",
    "@types/body-parser": "1.19.6",
    "@types/node": "catalog:",
    "@types/supertest": "catalog:",
    "body-parser": "2.2.2",
    "eslint": "catalog:",
    "express": "5.2.1",
    "openapi-types": "12.1.3",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "supertest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-config": "workspace:^"
  }
}
