{
  "name": "@map-colonies/eslint-config",
  "version": "9.0.0",
  "description": "eslint configs for map colonies organization",
  "type": "module",
  "exports": {
    "./ts-base": {
      "types": "./dist/configs/ts-base.d.mts",
      "import": "./dist/configs/ts-base.mjs"
    },
    "./react": {
      "types": "./dist/configs/react.d.mts",
      "import": "./dist/configs/react.mjs"
    },
    "./jest": {
      "types": "./dist/configs/jest.d.mts",
      "import": "./dist/configs/jest.mjs"
    },
    "./vitest": {
      "types": "./dist/configs/vitest.d.mts",
      "import": "./dist/configs/vitest.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers.d.mts",
      "import": "./dist/helpers.mjs"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "pretest": "turbo run build",
    "test": "vitest run",
    "prepack": "turbo run build",
    "prebuild": "pnpm run clean",
    "clean": "rimraf dist",
    "build": "tsc --project tsconfig.build.json",
    "check-dist": "publint && attw --profile esm-only --pack .",
    "knip": "knip --directory ../.. --workspace packages/eslint-config"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "repository": "github:MapColonies/infra-packages",
  "peerDependencies": {
    "@vitest/eslint-plugin": "^1.6.7",
    "eslint": "^10.0.0",
    "eslint-plugin-jest": "^29.13.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0 || ^7.0.0",
    "globals": "^15.14.0 || ^17.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jest": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "globals": {
      "optional": true
    }
  },
  "dependencies": {
    "eslint-import-resolver-typescript": "^4.0.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@map-colonies/eslint-plugin": "workspace:^",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "typescript-eslint": "^8.60.1"
  },
  "devDependencies": {
    "@map-colonies/tsconfig": "workspace:^",
    "@types/node": "catalog:",
    "@vitest/eslint-plugin": "1.6.19",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-config": "workspace:^"
  }
}
