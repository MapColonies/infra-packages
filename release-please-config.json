{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-sections": [
    {
      "section": "🎉 Features",
      "type": "feat"
    },
    {
      "section": "🐛 Bug Fixes",
      "type": "fix"
    },
    {
      "section": "⚡ Performance Improvements",
      "type": "perf"
    },
    {
      "section": "🔗 Dependencies",
      "type": "deps"
    },
    {
      "section": "📝 Documentation",
      "type": "docs"
    },
    {
      "section": "🏗️ Build System",
      "type": "build",
      "hidden": true
    },
    {
      "section": "🤖 Continuous Integration",
      "type": "ci",
      "hidden": true
    },
    {
      "section": "🔧 Miscellaneous Chores",
      "type": "chore",
      "hidden": true
    },
    {
      "section": "⏪ Reverts",
      "type": "revert"
    },
    {
      "section": "✅ Tests",
      "type": "test",
      "hidden": true
    },
    {
      "section": "💄 Style",
      "type": "style",
      "hidden": true
    },
    {
      "section": "♻️ Code Refactoring",
      "type": "refactor",
      "hidden": true
    }
  ],
  "draft-pull-request": false,
  "include-v-in-tag": true,
  "separate-pull-requests": true,
  "packages": {
    "packages/commitlint-config": {
      "package-name": "@map-colonies/commitlint-config",
      "release-type": "node"
    },
    "packages/eslint-config": {
      "package-name": "@map-colonies/eslint-config",
      "release-type": "node"
    },
    "packages/prettier-config": {
      "package-name": "@map-colonies/prettier-config",
      "release-type": "node"
    },
    "packages/typescript-config": {
      "package-name": "@map-colonies/tsconfig",
      "release-type": "node"
    },
    "packages/js-logger": {
      "package-name": "@map-colonies/js-logger",
      "release-type": "node"
    },
    "packages/read-pkg": {
      "package-name": "@map-colonies/read-pkg",
      "release-type": "node"
    },
    "packages/openapi-express-viewer": {
      "package-name": "@map-colonies/openapi-express-viewer",
      "release-type": "node"
    },
    "packages/openapi-helpers": {
      "package-name": "@map-colonies/openapi-helpers",
      "release-type": "node"
    },
    "packages/semantic-conventions": {
      "package-name": "@map-colonies/semantic-conventions",
      "release-type": "node"
    },
    "packages/tracing": {
      "package-name": "@map-colonies/tracing",
      "release-type": "node"
    },
    "packages/tracing-utils": {
      "package-name": "@map-colonies/tracing-utils",
      "release-type": "node"
    }
  }
}
